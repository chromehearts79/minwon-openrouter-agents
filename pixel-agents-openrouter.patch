+// ── External ServerMessage Injection ───────────────────────────
+
+function registerExternalMessageRoute(app: FastifyInstance, options: HttpServerOptions): void {
+  app.post<{
+    Body: Record<string, unknown> | Record<string, unknown>[];
+  }>('/api/external/messages', async (request, reply) => {
+    const body = request.body;
+    const messages = Array.isArray(body)
+      ? body
+      : Array.isArray(body.messages)
+        ? (body.messages as Record<string, unknown>[])
+        : [body];
+
+    for (const message of messages) {
+      if (message && typeof message.type === 'string') {
+        options.store.broadcast(message);
+      }
+    }
+
+    reply.send({ ok: true, count: messages.length });
+  });
+}
+
